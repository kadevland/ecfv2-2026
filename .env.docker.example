# Docker Environment Variables - Cinéphoria ECF
# Ces variables sont utilisées par Docker Compose et peuvent être surchargées

# =============================================================================
# APPLICATION
# =============================================================================
APP_PORT=80
APP_ENV=local
DOCKER_PATH=./docker
DOCKER_APP_NAME=ecf.app
DOCKER_NODE_NAME=ecf.node
VITE_PORT=5173

# =============================================================================
# DATABASE POSTGRESQL + PGBOUNCER
# =============================================================================
POSTGRES_CONTAINER_NAME=ecf.postgres
POSTGRES_PORT=5432
POSTGRES_DB=cinephoria
POSTGRES_USER=cinephoria_user
POSTGRES_PASSWORD=password123
POSTGRES_ROOT_PASSWORD=root123
POSTGRES_VOLUME_PATH=./docker-volumes/postgresql

# PgBouncer connection pooling
PGBOUNCER_CONTAINER_NAME=ecf.pgbouncer
PGBOUNCER_PORT=6432

# =============================================================================
# DATABASE MONGODB
# =============================================================================
MONGODB_CONTAINER_NAME=ecf.mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=cinephoria_read
MONGODB_USERNAME=cinephoria_mongo_user
MONGODB_PASSWORD=password123
MONGODB_ROOT_PASSWORD=root123
MONGODB_VOLUME_PATH=./docker-volumes/mongodb

# =============================================================================
# REDIS
# =============================================================================
REDIS_CONTAINER_NAME=ecf.redis
REDIS_PORT=6379
REDIS_PASSWORD=password123
REDIS_VOLUME_PATH=./docker-volumes/redis

# =============================================================================
# DEVELOPMENT TOOLS PORTS (dev only)
# =============================================================================
MAILPIT_PORT=8025
MAILPIT_SMTP_PORT=1025
PGADMIN_PORT=8080
PGADMIN_EMAIL=admin@cinephoria.dev
PGADMIN_PASSWORD=password123
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=password123
REDIS_COMMANDER_PORT=8082
REDIS_COMMANDER_USERNAME=admin
REDIS_COMMANDER_PASSWORD=password123
DALIBO_EXPLAIN_PORT=5000

# =============================================================================
# NETWORKS
# =============================================================================
NETWORK_NAME=ecf_network

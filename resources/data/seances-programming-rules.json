{
  "programming_rules": {
    "time_slots": [
      {
        "start": "09:00",
        "end": "11:30",
        "period": "morning",
        "label": "Matinée",
        "break_minutes": 30
      },
      {
        "start": "14:00",
        "end": "16:30",
        "period": "afternoon",
        "label": "Après-midi",
        "break_minutes": 30
      },
      {
        "start": "17:00",
        "end": "19:30",
        "period": "early_evening",
        "label": "Début de soirée",
        "break_minutes": 30
      },
      {
        "start": "20:00",
        "end": "22:30",
        "period": "evening",
        "label": "Soirée",
        "break_minutes": 30
      }
    ],
    "genre_restrictions": {
      "Horreur": {
        "forbidden_periods": ["morning"],
        "preferred_periods": ["evening"],
        "comment": "Pas d'horreur le matin"
      },
      "Famille": {
        "forbidden_periods": ["evening"],
        "preferred_periods": ["morning", "afternoon", "early_evening"],
        "comment": "Pas de films famille tard le soir"
      },
      "Animation": {
        "preferred_periods": ["morning", "afternoon"],
        "comment": "Animation plutôt en journée"
      },
      "Thriller": {
        "forbidden_periods": ["morning"],
        "preferred_periods": ["early_evening", "evening"],
        "comment": "Thriller en soirée de préférence"
      },
      "Romance": {
        "preferred_periods": ["early_evening", "evening"],
        "comment": "Romance en soirée"
      }
    },
    "frequency_patterns": {
      "high_demand": {
        "days_offset": [1, 3, 5, 7, 10, 12, 15, 18, 21, 25, 28, 32, 35, 39, 42, 46, 49, 53, 56, 60],
        "genres": ["Action", "Comédie", "Aventure", "Animation"],
        "comment": "Films populaires - diffusion fréquente"
      },
      "medium_demand": {
        "days_offset": [2, 6, 9, 14, 17, 23, 26, 31, 38, 44, 50, 57],
        "genres": ["Drame", "Romance", "Thriller", "Science-Fiction"],
        "comment": "Films moyennement populaires"
      },
      "low_demand": {
        "days_offset": [7, 14, 21, 35, 49],
        "genres": ["Biographie", "Documentaire", "Historique", "Mystère"],
        "comment": "Films de niche - diffusion espacée"
      },
      "special_demand": {
        "days_offset": [4, 11, 18, 29, 40, 54],
        "genres": ["Horreur", "Crime", "Guerre", "Western"],
        "comment": "Films spécialisés - audiences spécifiques"
      }
    }
  },
  "tarifs_default": {
    "normal": 12.50,
    "reduit": 9.50,
    "enfant": 7.50
  },
  "technical_settings": {
    "duree_additionnelle_minutes": 30,
    "taux_tva": 20.0,
    "devise": "EUR",
    "statut_defaut": "PROGRAMMEE",
    "placement_libre": false,
    "version_defaut": "vf"
  },
  "generation_limits": {
    "max_seances_per_day_per_room": 4,
    "min_break_between_seances_minutes": 30,
    "max_days_ahead": 60,
    "avoid_conflicts": true
  }
}